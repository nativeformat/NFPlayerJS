{
  "name": "nf-player",
  "version": "0.11.0",
  "description": "The Native Format Smart Player, JS Edition",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "bin": {
    "nf-player": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:nativeformat/NFPlayerJS.git"
  },
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b package.tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.cache",
    "prepare": "husky"
  },
  "author": "Drew Petersen <kirbysayshi@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "cross-fetch": "3.0.4",
    "debug": "4.4.3",
    "nf-grapher": "1.2.24",
    "pseudo-audio-param": "1.3.1",
    "soundtouch-ts": "1.1.1",
    "tempy": "0.5.0",
    "wav-decoder": "1.3.0",
    "wav-encoder": "1.3.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@eslint/js": "10.0.1",
    "@types/debug": "4.1.13",
    "@types/node": "25.9.1",
    "@types/pseudo-audio-param": "1.3.3",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "publint": "0.3.21",
    "tsdown": "0.22.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7",
    "web-audio-test-api": "0.5.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,css,yaml,yml}": "prettier --write",
    "*.{js,ts,tsx}": "eslint --fix"
  }
}
